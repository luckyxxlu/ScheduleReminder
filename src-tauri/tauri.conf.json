{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "时间助手",
  "version": "1.0.1",
  "identifier": "com.schedulereminder.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "时间助手",
        "width": 1280,
        "height": 960,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "ScheduleReminder Team",
    "shortDescription": "Windows 桌面作息提醒工具",
    "copyright": "Copyright 2026 ScheduleReminder Team",
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": true
      }
    }
  }
}
