{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ScheduleReminder",
  "version": "1.0.0",
  "identifier": "com.schedulereminder.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "ScheduleReminder",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
